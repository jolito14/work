<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Patient Journey Intelligence · MVP interactivo</title>
  <style>
    :root{
      --bg:#f4f7fb;
      --surface:#ffffff;
      --surface-2:#f8fafc;
      --surface-3:#eef6ff;
      --text:#102033;
      --muted:#607086;
      --soft:#8a99ad;
      --border:#dde6f0;
      --primary:#2563eb;
      --primary-dark:#1e40af;
      --primary-soft:#e9f2ff;
      --green:#16a34a;
      --green-soft:#e9f8ef;
      --yellow:#f59e0b;
      --yellow-soft:#fff7e6;
      --red:#dc2626;
      --red-soft:#fff0f0;
      --shadow:0 18px 55px rgba(16,32,51,.10);
      --radius:24px;
      --radius-sm:16px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{margin:0;font-family:Inter,Roboto,Segoe UI,Arial,sans-serif;background:var(--bg);color:var(--text)}
    button,input,select,textarea{font:inherit}
    button{cursor:pointer}
    .app{min-height:100vh;display:grid;grid-template-columns:86px 270px 1fr;background:linear-gradient(135deg,#f6f9ff,#eef6fb)}
    .rail{background:#0d2442;color:white;padding:22px 16px;display:flex;flex-direction:column;align-items:center;gap:18px;position:sticky;top:0;height:100vh}
    .rail-logo{width:46px;height:46px;border-radius:16px;background:linear-gradient(135deg,var(--primary),#2dd4bf);display:grid;place-items:center;font-weight:900;box-shadow:0 12px 30px rgba(37,99,235,.35)}
    .rail-btn{width:46px;height:46px;border:0;border-radius:16px;background:rgba(255,255,255,.09);color:#dbeafe;display:grid;place-items:center;font-size:20px}
    .rail-btn.active,.rail-btn:hover{background:#fff;color:var(--primary)}
    .rail-spacer{flex:1}.avatar{width:42px;height:42px;border-radius:50%;background:#fff;color:#0d2442;font-weight:800;display:grid;place-items:center}
    .side{background:#fff;border-right:1px solid var(--border);padding:24px 18px;position:sticky;top:0;height:100vh;overflow:auto}
    .side h1{font-size:21px;line-height:1.1;margin:0 0 6px}.side p{font-size:13px;color:var(--muted);line-height:1.45;margin:0 0 22px}
    .nav{display:flex;flex-direction:column;gap:8px}.nav button{border:0;background:transparent;text-align:left;border-radius:16px;padding:13px 14px;color:var(--muted);display:flex;gap:10px;align-items:center;font-weight:700}.nav button.active{background:var(--primary-soft);color:var(--primary)}.nav button:hover{background:#f4f7fb;color:var(--primary)}
    .content{padding:28px;overflow:auto}.view{display:none}.view.active{display:block;animation:fade .22s ease}@keyframes fade{from{opacity:.2;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
    .hero{display:flex;align-items:flex-end;justify-content:space-between;gap:18px;margin-bottom:22px}.eyebrow{font-size:12px;text-transform:uppercase;letter-spacing:.12em;color:var(--primary);font-weight:900}.hero h2{font-size:32px;margin:5px 0 6px;letter-spacing:-.03em}.hero p{margin:0;color:var(--muted);line-height:1.45}.btn{border:0;border-radius:999px;padding:12px 18px;font-weight:800;display:inline-flex;align-items:center;gap:8px}.btn-primary{background:var(--primary);color:#fff}.btn-primary:hover{background:var(--primary-dark)}.btn-light{background:#fff;color:var(--text);border:1px solid var(--border)}.btn-soft{background:var(--primary-soft);color:var(--primary)}
    .layout{display:grid;grid-template-columns:410px 1fr;gap:24px;align-items:start}.panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow)}.panel-pad{padding:22px}.section-title{font-size:18px;margin:0 0 4px}.section-sub{font-size:13px;color:var(--muted);margin:0;line-height:1.45}
    .phone-wrap{display:flex;justify-content:center}.phone{width:360px;min-height:690px;background:#0f172a;border-radius:46px;padding:12px;box-shadow:0 24px 70px rgba(15,23,42,.3);position:sticky;top:20px}.phone-inner{background:#fff;border-radius:36px;min-height:666px;overflow:hidden;display:flex;flex-direction:column}.phone-status{height:42px;display:flex;align-items:center;justify-content:space-between;padding:0 22px;font-weight:800;font-size:13px}.dot{width:9px;height:9px;border-radius:50%;background:#94a3b8}.mobile-screen{display:none;flex:1;padding:22px;flex-direction:column}.mobile-screen.active{display:flex}.progress-row{display:flex;gap:10px;align-items:center;margin-bottom:22px;color:var(--muted);font-weight:800;font-size:12px}.progress{height:7px;background:#e8eef7;border-radius:999px;flex:1;overflow:hidden}.progress > span{display:block;height:100%;background:var(--primary);width:0%;transition:.25s}.mobile-screen h3{font-size:25px;line-height:1.12;letter-spacing:-.03em;margin:0 0 10px}.mobile-screen p{font-size:15px;line-height:1.45;color:var(--muted);margin:0}.mobile-center{display:flex;flex-direction:column;align-items:center;text-align:center;justify-content:space-between;gap:22px;min-height:590px}.icon-circle{width:86px;height:86px;border-radius:28px;background:var(--primary-soft);display:grid;place-items:center;color:var(--primary);font-size:34px}.small-note{font-size:12px!important;color:var(--soft)!important}.options{display:flex;flex-direction:column;gap:12px;margin-top:18px}.option{width:100%;border:1.5px solid var(--border);background:#fbfdff;border-radius:18px;padding:16px;text-align:left;display:flex;align-items:center;gap:12px;font-weight:800;color:var(--text);transition:.16s}.option:hover{border-color:#a8c7ff;background:#f7fbff}.option.selected{border-color:var(--primary);background:var(--primary-soft);box-shadow:0 0 0 3px rgba(37,99,235,.08)}.option .emoji{font-size:22px;width:30px;text-align:center}.chip-grid{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px}.chip{border:1.5px solid var(--border);background:#fff;border-radius:999px;padding:11px 13px;font-weight:800;color:var(--text);font-size:14px}.chip.selected{background:var(--primary);border-color:var(--primary);color:#fff}.textarea{margin-top:16px;width:100%;min-height:160px;border:1.5px solid var(--border);border-radius:18px;padding:16px;resize:vertical;background:#fbfdff;color:var(--text)}.mobile-actions{margin-top:auto;display:flex;flex-direction:column;gap:10px}.link-btn{border:0;background:transparent;color:var(--muted);font-weight:800;padding:10px}.pill-note{display:inline-flex;align-items:center;gap:6px;border-radius:999px;background:#f4f7fb;color:var(--muted);padding:8px 11px;font-size:12px;font-weight:800}
    .filters{display:flex;gap:10px;flex-wrap:wrap;align-items:center}.filter{background:#fff;border:1px solid var(--border);border-radius:14px;padding:10px 12px;font-size:13px;color:var(--text);min-width:145px}.kpi-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px;margin:18px 0}.kpi{background:#fff;border:1px solid var(--border);border-radius:22px;padding:18px;box-shadow:0 10px 35px rgba(16,32,51,.06);min-height:142px}.kpi-head{display:flex;justify-content:space-between;align-items:center;gap:10px;color:var(--muted);font-size:13px;font-weight:800}.status-dot{width:10px;height:10px;border-radius:50%}.good{background:var(--green)}.warn{background:var(--yellow)}.bad{background:var(--red)}.kpi-value{font-size:36px;line-height:1;margin:18px 0 4px;font-weight:900;letter-spacing:-.04em}.kpi-delta{font-size:13px;font-weight:800}.delta-good{color:var(--green)}.delta-warn{color:var(--yellow)}.delta-bad{color:var(--red)}.kpi small{display:block;margin-top:10px;color:var(--muted);line-height:1.3}.dash-grid{display:grid;grid-template-columns:1.25fr .85fr;gap:18px}.stage-bars{display:flex;flex-direction:column;gap:13px;margin-top:18px}.stage-row{display:grid;grid-template-columns:160px 1fr 52px;gap:12px;align-items:center}.bar{height:14px;border-radius:999px;background:#edf2f7;overflow:hidden}.bar span{display:block;height:100%;border-radius:999px;width:50%;transition:.25s}.stage-name{font-weight:800;font-size:13px;color:var(--text)}.score{text-align:right;font-weight:900}.alert-list,.comment-list,.action-list{display:flex;flex-direction:column;gap:12px;margin-top:14px}.alert,.comment,.action{border:1px solid var(--border);border-radius:18px;padding:14px;background:#fff}.alert.red{border-color:#fecaca;background:var(--red-soft)}.alert.yellow{border-color:#fed7aa;background:var(--yellow-soft)}.alert-title{font-weight:900;margin-bottom:4px}.meta{font-size:12px;color:var(--muted);line-height:1.35}.tag{display:inline-flex;align-items:center;border-radius:999px;padding:5px 8px;font-size:11px;font-weight:900;margin-right:5px}.tag-red{background:#fee2e2;color:#991b1b}.tag-yellow{background:#fef3c7;color:#92400e}.tag-green{background:#dcfce7;color:#166534}.tag-blue{background:#dbeafe;color:#1e40af}.table{width:100%;border-collapse:separate;border-spacing:0 10px;margin-top:12px}.table th{text-align:left;color:var(--muted);font-size:12px;padding:0 10px}.table td{background:#fff;border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:12px 10px;font-size:13px}.table td:first-child{border-left:1px solid var(--border);border-radius:14px 0 0 14px}.table td:last-child{border-right:1px solid var(--border);border-radius:0 14px 14px 0}.mini-btn{border:1px solid var(--border);border-radius:999px;background:#fff;color:var(--primary);font-weight:900;padding:8px 10px}.insight-box{border:1px solid #bfdbfe;background:#eff6ff;border-radius:18px;padding:14px;margin-top:14px}.insight-box b{display:block;margin-bottom:6px}.flow{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;align-items:stretch;margin-top:18px}.flow-step{background:#fff;border:1px solid var(--border);border-radius:20px;padding:16px;position:relative;min-height:126px}.flow-step:not(:last-child)::after{content:'→';position:absolute;right:-13px;top:46%;font-weight:900;color:var(--primary)}.flow-step b{display:block;margin-bottom:6px}.flow-step p{font-size:12px;color:var(--muted);line-height:1.4;margin:0}.debug{background:#0f172a;color:#dbeafe;border-radius:18px;padding:14px;margin-top:16px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:12px;line-height:1.55;overflow:auto}.two-col{display:grid;grid-template-columns:1fr 1fr;gap:18px}.empty{color:var(--muted);font-size:13px;padding:14px;border:1px dashed var(--border);border-radius:16px;background:#fbfdff}.toast{position:fixed;right:22px;bottom:22px;background:#0f172a;color:#fff;border-radius:18px;padding:14px 16px;box-shadow:0 18px 45px rgba(15,23,42,.25);display:none;z-index:10}.toast.show{display:block;animation:fade .2s ease}.modal{position:fixed;inset:0;background:rgba(15,23,42,.35);display:none;align-items:center;justify-content:center;z-index:20;padding:18px}.modal.show{display:flex}.modal-card{background:#fff;border-radius:26px;max-width:560px;width:100%;padding:22px;box-shadow:var(--shadow)}.modal-card h3{margin:0 0 8px;font-size:24px}.modal-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:18px;flex-wrap:wrap}.legend{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;color:var(--muted);font-size:12px}.legend span{display:flex;align-items:center;gap:6px}.legend i{width:10px;height:10px;border-radius:50%;display:inline-block}.hidden{display:none!important}
    @media(max-width:1100px){.app{grid-template-columns:1fr}.rail,.side{display:none}.content{padding:16px}.layout,.dash-grid,.two-col{grid-template-columns:1fr}.phone{position:relative;top:auto}.kpi-grid{grid-template-columns:repeat(2,1fr)}.flow{grid-template-columns:1fr}.flow-step:not(:last-child)::after{content:'↓';right:18px;top:auto;bottom:-16px}.hero{align-items:flex-start;flex-direction:column}.stage-row{grid-template-columns:120px 1fr 45px}}
    @media(max-width:560px){.content{padding:10px}.phone{width:100%;border-radius:32px;padding:8px;min-height:650px}.phone-inner{border-radius:26px;min-height:630px}.mobile-center{min-height:555px}.kpi-grid{grid-template-columns:1fr}.hero h2{font-size:25px}.panel-pad{padding:16px}.flow-step{min-height:auto}.stage-row{grid-template-columns:1fr}.score{text-align:left}.filters .filter{width:100%}}
  </style>
</head>
<body>
  <div class="app">
    <aside class="rail" aria-label="Navegación principal">
      <div class="rail-logo">PJ</div>
      <button class="rail-btn active" data-nav="prototype" title="Prototipo">⌁</button>
      <button class="rail-btn" data-nav="dashboard" title="Dashboard">▦</button>
      <button class="rail-btn" data-nav="architecture" title="Arquitectura">⟲</button>
      <div class="rail-spacer"></div><div class="avatar">DR</div>
    </aside>
    <aside class="side">
      <h1>Patient Journey Intelligence</h1>
      <p>MVP interactivo para validar captura, procesamiento, dashboard y activación operativa.</p>
      <div class="nav">
        <button class="active" data-nav="prototype">📱 Prueba end-to-end</button>
        <button data-nav="dashboard">📊 Dashboard B2B</button>
        <button data-nav="architecture">🔁 Arquitectura del flujo</button>
      </div>
    </aside>
    <main class="content">
      <section id="prototype" class="view active">
        <div class="hero">
          <div>
            <div class="eyebrow">MVP temprano · funcional</div>
            <h2>Captura del paciente → Dashboard operativo</h2>
            <p>Responde el flujo mobile y observa cómo se actualizan automáticamente los KPIs, alertas, comentarios e insights del dashboard.</p>
          </div>
          <div class="filters">
            <button class="btn btn-light" id="resetBtn">Reiniciar prueba</button>
            <button class="btn btn-primary" data-nav="dashboard">Ver dashboard</button>
          </div>
        </div>
        <div class="layout">
          <div class="phone-wrap">
            <div class="phone" aria-label="Interfaz paciente mobile-first">
              <div class="phone-inner">
                <div class="phone-status"><span>9:41</span><span class="dot"></span></div>

                <div class="mobile-screen active" data-step="0">
                  <div class="mobile-center">
                    <div>
                      <div class="icon-circle">♡</div>
                      <h3 style="margin-top:22px">Queremos saber cómo fue tu atención hoy</h3>
                      <p>Son solo 3 preguntas. Si deseas, puedes contarnos más al final.</p>
                      <div style="margin-top:18px" class="pill-note">⏱ Menos de 2 minutos</div>
                    </div>
                    <div style="width:100%">
                      <button class="btn btn-primary" style="width:100%;justify-content:center" onclick="nextStep()">Comenzar</button>
                      <p class="small-note" style="margin-top:12px">Tu opinión será revisada para mejorar el servicio.</p>
                    </div>
                  </div>
                </div>

                <div class="mobile-screen" data-step="1">
                  <div class="progress-row"><span>1 de 5</span><div class="progress"><span style="width:20%"></span></div></div>
                  <h3>En general, ¿cómo fue tu experiencia en la clínica?</h3>
                  <p>Elige la opción que mejor resume tu atención.</p>
                  <div class="options" id="globalOptions">
                    <button class="option" data-value="5"><span class="emoji">😊</span>Muy buena</button>
                    <button class="option" data-value="4"><span class="emoji">🙂</span>Buena</button>
                    <button class="option" data-value="3"><span class="emoji">😐</span>Regular</button>
                    <button class="option" data-value="2"><span class="emoji">🙁</span>Mala</button>
                    <button class="option" data-value="1"><span class="emoji">😟</span>Muy mala</button>
                  </div>
                  <div class="mobile-actions"><button class="btn btn-primary" onclick="nextStep()">Continuar</button></div>
                </div>

                <div class="mobile-screen" data-step="2">
                  <div class="progress-row"><span>2 de 5</span><div class="progress"><span style="width:40%"></span></div></div>
                  <h3>¿En qué parte de tu atención ocurrió lo más importante?</h3>
                  <p>Esto ayuda a ubicar dónde mejorar. También puedes elegir “No estoy seguro/a”.</p>
                  <div class="options" id="stageOptions">
                    <button class="option" data-stage="admission"><span class="emoji">🧾</span>Acceso / admisión</button>
                    <button class="option" data-stage="wait"><span class="emoji">⏱</span>Tiempo de espera</button>
                    <button class="option" data-stage="clinical"><span class="emoji">🩺</span>Atención clínica</button>
                    <button class="option" data-stage="communication"><span class="emoji">💬</span>Comunicación</button>
                    <button class="option" data-stage="admin"><span class="emoji">📄</span>Proceso administrativo</button>
                    <button class="option" data-stage="unknown"><span class="emoji">❔</span>No estoy seguro/a</button>
                  </div>
                  <div class="mobile-actions"><button class="btn btn-primary" onclick="renderContextQuestion(); nextStep()">Continuar</button></div>
                </div>

                <div class="mobile-screen" data-step="3">
                  <div class="progress-row"><span>3 de 5</span><div class="progress"><span style="width:60%"></span></div></div>
                  <span class="tag tag-blue" id="stageBadge">Etapa</span>
                  <h3 id="contextQuestion" style="margin-top:10px">¿Sentiste que te explicaron con claridad?</h3>
                  <p>Esta pregunta se adapta a la etapa elegida.</p>
                  <div class="options" id="contextOptions">
                    <button class="option" data-value="5"><span class="emoji">✅</span>Sí, completamente</button>
                    <button class="option" data-value="3"><span class="emoji">◐</span>Más o menos</button>
                    <button class="option" data-value="1"><span class="emoji">✕</span>No</button>
                  </div>
                  <div class="mobile-actions"><button class="btn btn-primary" onclick="handleContextContinue()">Continuar</button></div>
                </div>

                <div class="mobile-screen" data-step="4">
                  <div class="progress-row"><span>4 de 5</span><div class="progress"><span style="width:80%"></span></div></div>
                  <h3>¿Qué fue lo que más afectó tu experiencia?</h3>
                  <p>Puedes elegir hasta 2. Esto permite detectar fricciones operativas.</p>
                  <div class="chip-grid" id="frictionOptions">
                    <button class="chip" data-friction="Tiempo de espera">Mucha espera</button>
                    <button class="chip" data-friction="Falta de información">Falta de información</button>
                    <button class="chip" data-friction="Trato poco amable">Trato poco amable</button>
                    <button class="chip" data-friction="No entendí indicaciones">No entendí las indicaciones</button>
                    <button class="chip" data-friction="Trámite confuso">Trámite confuso</button>
                    <button class="chip" data-friction="Problema de coordinación">Problema de coordinación</button>
                    <button class="chip" data-friction="Otro">Otro</button>
                  </div>
                  <div class="mobile-actions"><button class="btn btn-primary" onclick="nextStep()">Continuar</button></div>
                </div>

                <div class="mobile-screen" data-step="5">
                  <div class="progress-row"><span>5 de 5</span><div class="progress"><span style="width:100%"></span></div></div>
                  <h3>Si deseas, cuéntanos brevemente qué ocurrió.</h3>
                  <p>Este comentario ayuda a entender mejor el problema.</p>
                  <textarea class="textarea" id="patientComment" placeholder="Ejemplo: esperé mucho y nadie me informó el motivo..."></textarea>
                  <div class="mobile-actions">
                    <button class="btn btn-primary" onclick="submitExperience()">Enviar respuesta</button>
                    <button class="link-btn" onclick="submitExperience(true)">Omitir comentario</button>
                  </div>
                </div>

                <div class="mobile-screen" data-step="6">
                  <div class="mobile-center">
                    <div>
                      <div class="icon-circle" id="finalIcon" style="background:var(--green-soft);color:var(--green)">✓</div>
                      <h3 id="finalTitle" style="margin-top:22px">Gracias. Tu comentario ayuda a detectar mejoras concretas.</h3>
                      <p id="finalText">La clínica podrá revisar esta información para mejorar la atención.</p>
                      <div style="margin-top:18px" class="pill-note" id="caseCode">Respuesta registrada</div>
                    </div>
                    <div style="width:100%">
                      <button class="btn btn-primary" style="width:100%;justify-content:center" data-nav="dashboard">Ver impacto en dashboard</button>
                      <button class="link-btn" onclick="resetPatientFlow()">Registrar otra respuesta</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div>
            <div class="panel panel-pad">
              <div class="eyebrow">Dashboard espejo · actualización en vivo</div>
              <h3 class="section-title">Impacto inmediato de la última respuesta</h3>
              <p class="section-sub">Cada respuesta se convierte en puntajes, clasificación, KPIs por etapa, alertas y comentarios visibles para gestión.</p>
              <div class="kpi-grid" style="grid-template-columns:repeat(2,1fr)">
                <div class="kpi"><div class="kpi-head"><span>Experiencia global</span><span class="status-dot" id="mirrorGlobalDot"></span></div><div class="kpi-value"><span id="mirrorGlobal">—</span></div><div class="kpi-delta" id="mirrorGlobalLabel">Sin datos</div><small>Score promedio convertido a escala 0–100.</small></div>
                <div class="kpi"><div class="kpi-head"><span>Etapa afectada</span><span class="status-dot" id="mirrorStageDot"></span></div><div class="kpi-value" style="font-size:24px"><span id="mirrorStage">—</span></div><div class="kpi-delta" id="mirrorStageLabel">Pendiente</div><small>Ubica el punto del journey asociado al feedback.</small></div>
              </div>
              <div class="insight-box">
                <b>Insight automático</b>
                <span id="mirrorInsight">Completa el flujo del paciente para generar un insight operativo.</span>
              </div>
              <div class="debug" id="processingBox">Esperando respuesta del paciente...</div>
            </div>
          </div>
        </div>
      </section>

      <section id="dashboard" class="view">
        <div class="hero">
          <div>
            <div class="eyebrow">Dashboard B2B · IPRESS privada</div>
            <h2>Patient Journey Intelligence Dashboard</h2>
            <p>Experiencia del paciente, fricciones operativas y acciones de mejora · Última actualización: <span id="lastUpdate">sin datos nuevos</span></p>
          </div>
          <div class="filters">
            <select class="filter"><option>Últimos 7 días</option><option>Últimos 30 días</option></select>
            <select class="filter"><option>Todas las sedes</option><option>San Isidro</option><option>Surco</option></select>
            <select class="filter"><option>Todos los servicios</option><option>Consulta externa</option><option>Emergencia</option></select>
            <button class="btn btn-soft" onclick="seedScenario()">Cargar escenario demo</button>
          </div>
        </div>
        <div class="kpi-grid">
          <div class="kpi"><div class="kpi-head"><span>Satisfacción global</span><span class="status-dot" id="kpiGlobalDot"></span></div><div class="kpi-value"><span id="kpiGlobal">—</span></div><div class="kpi-delta" id="kpiGlobalDelta">Sin datos</div><small>Promedio de respuestas PREMs agregadas.</small></div>
          <div class="kpi"><div class="kpi-head"><span>Tiempo de espera percibido</span><span class="status-dot" id="kpiWaitDot"></span></div><div class="kpi-value"><span id="kpiWait">—</span></div><div class="kpi-delta" id="kpiWaitDelta">Sin datos</div><small>Indicador de fricción en la etapa de espera.</small></div>
          <div class="kpi"><div class="kpi-head"><span>Trato recibido</span><span class="status-dot" id="kpiTreatDot"></span></div><div class="kpi-value"><span id="kpiTreat">—</span></div><div class="kpi-delta" id="kpiTreatDelta">Sin datos</div><small>Percepción de respeto, escucha y empatía.</small></div>
          <div class="kpi"><div class="kpi-head"><span>Comprensión del paciente</span><span class="status-dot" id="kpiUnderstandDot"></span></div><div class="kpi-value"><span id="kpiUnderstand">—</span></div><div class="kpi-delta" id="kpiUnderstandDelta">Sin datos</div><small>Claridad de explicación e indicaciones.</small></div>
        </div>
        <div class="dash-grid">
          <div class="panel panel-pad">
            <h3 class="section-title">Análisis por etapas del Patient Journey</h3>
            <p class="section-sub">Score por etapa y visualización simple de puntos de fricción.</p>
            <div class="stage-bars" id="stageBars"></div>
            <div class="legend"><span><i class="good"></i> ≥75 positivo</span><span><i class="warn"></i> 50–74 atención</span><span><i class="bad"></i> &lt;50 crítico</span></div>
          </div>
          <div class="panel panel-pad">
            <h3 class="section-title">Alertas operativas</h3>
            <p class="section-sub">Problemas detectados que requieren revisión o service recovery.</p>
            <div class="alert-list" id="alertsList"><div class="empty">Sin alertas. Registra una respuesta negativa o carga escenario demo.</div></div>
          </div>
        </div>
        <div class="two-col" style="margin-top:18px">
          <div class="panel panel-pad">
            <h3 class="section-title">Voz del paciente</h3>
            <p class="section-sub">Comentarios cualitativos categorizados por etapa y problema.</p>
            <div class="comment-list" id="commentsList"><div class="empty">Aún no hay comentarios registrados.</div></div>
          </div>
          <div class="panel panel-pad">
            <h3 class="section-title">Módulo de acción · service recovery</h3>
            <p class="section-sub">Casos generados por alertas. Permite asignar, escalar y cerrar acciones.</p>
            <table class="table" aria-label="Casos de service recovery">
              <thead><tr><th>Caso</th><th>Problema</th><th>Estado</th><th>Acción</th></tr></thead>
              <tbody id="casesTable"><tr><td colspan="4" style="border-radius:14px;border:1px dashed var(--border);color:var(--muted)">Sin casos abiertos.</td></tr></tbody>
            </table>
          </div>
        </div>
      </section>

      <section id="architecture" class="view">
        <div class="hero">
          <div>
            <div class="eyebrow">Arquitectura end-to-end</div>
            <h2>De la voz del paciente a la acción operativa</h2>
            <p>Representación del ciclo funcional integrado para validación del MVP.</p>
          </div>
        </div>
        <div class="panel panel-pad">
          <div class="flow">
            <div class="flow-step"><b>1. Captura mobile</b><p>El paciente responde preguntas simples, por etapa, con baja fricción.</p></div>
            <div class="flow-step"><b>2. Estructuración</b><p>El sistema convierte respuestas en puntajes, etapa, categoría y comentario.</p></div>
            <div class="flow-step"><b>3. Motor analítico</b><p>Clasifica positivo/neutro/negativo y detecta fricciones críticas.</p></div>
            <div class="flow-step"><b>4. Dashboard</b><p>Actualiza KPIs, barras por etapa, alertas y voz del paciente.</p></div>
            <div class="flow-step"><b>5. Acción</b><p>Genera caso para service recovery o mejora de proceso.</p></div>
            <div class="flow-step"><b>6. Re-medición</b><p>Permite evaluar si la intervención reduce la fricción.</p></div>
          </div>
          <div class="insight-box" style="margin-top:22px">
            <b>Regla del prototipo</b>
            <span>Una respuesta con score bajo o fricción sensible genera alerta y caso. Los casos pueden cerrarse para simular el cierre del ciclo.</span>
          </div>
        </div>
      </section>
    </main>
  </div>

  <div class="toast" id="toast"></div>
  <div class="modal" id="caseModal" role="dialog" aria-modal="true">
    <div class="modal-card">
      <h3 id="modalTitle">Caso</h3>
      <p class="section-sub" id="modalDesc"></p>
      <div class="debug" id="modalPayload"></div>
      <div class="modal-actions">
        <button class="btn btn-light" onclick="closeModal()">Cerrar</button>
        <button class="btn btn-soft" onclick="setCaseStatus('En proceso')">Marcar en proceso</button>
        <button class="btn btn-primary" onclick="setCaseStatus('Resuelto')">Marcar como resuelto</button>
      </div>
    </div>
  </div>

  <script>
    const stageLabels = {
      admission:'Acceso / admisión', wait:'Tiempo de espera', clinical:'Atención clínica',
      communication:'Comunicación', admin:'Proceso administrativo', unknown:'No estoy seguro/a'
    };
    const stageQuestions = {
      admission:'¿Fue fácil orientarte y completar tu ingreso?',
      wait:'¿Durante la espera recibiste información clara sobre la demora?',
      clinical:'¿Sentiste que te escucharon y trataron con respeto?',
      communication:'¿Te explicaron de forma clara tu diagnóstico o tratamiento?',
      admin:'¿El trámite fue claro y sencillo?',
      unknown:'¿Sentiste que la atención fue clara y ordenada?'
    };
    const metricMap = {
      admission:'global', wait:'wait', clinical:'treat', communication:'understand', admin:'global', unknown:'global'
    };
    let currentStep = 0;
    let currentCaseId = null;
    let responseDraft = { global:null, stage:null, context:null, frictions:[], comment:'' };
    let state = {
      responses: [],
      cases: [],
      lastSubmitted: null
    };

    function q(sel){ return document.querySelector(sel); }
    function qa(sel){ return Array.from(document.querySelectorAll(sel)); }
    function showToast(msg){ const t=q('#toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2400); }
    function statusClass(score){ if(score>=75) return 'good'; if(score>=50) return 'warn'; return 'bad'; }
    function statusLabel(score){ if(score>=75) return 'Positivo'; if(score>=50) return 'Atención'; return 'Crítico'; }
    function scoreTo100(v){ return Math.round((Number(v||0)/5)*100); }
    function classifyScore(score){ if(score>=75) return 'positivo'; if(score>=50) return 'neutro'; return 'negativo'; }

    function navigate(view){
      qa('.view').forEach(v=>v.classList.remove('active'));
      q('#'+view).classList.add('active');
      qa('[data-nav]').forEach(b=> b.classList.toggle('active', b.dataset.nav===view));
      window.scrollTo({top:0,behavior:'smooth'});
    }
    document.addEventListener('click', (e)=>{
      const nav = e.target.closest('[data-nav]');
      if(nav){ navigate(nav.dataset.nav); }
    });

    function setStep(n){
      currentStep=n;
      qa('.mobile-screen').forEach(s=>s.classList.toggle('active', Number(s.dataset.step)===n));
    }
    function nextStep(){ setStep(currentStep+1); }

    function setupSingleOptions(containerId, key){
      q(containerId).addEventListener('click', (e)=>{
        const btn=e.target.closest('button'); if(!btn) return;
        q(containerId).querySelectorAll('button').forEach(b=>b.classList.remove('selected'));
        btn.classList.add('selected');
        if(key==='stage') responseDraft.stage = btn.dataset.stage;
        else responseDraft[key] = Number(btn.dataset.value);
      });
    }
    setupSingleOptions('#globalOptions','global');
    setupSingleOptions('#stageOptions','stage');
    setupSingleOptions('#contextOptions','context');

    q('#frictionOptions').addEventListener('click',(e)=>{
      const btn=e.target.closest('button'); if(!btn) return;
      const value=btn.dataset.friction;
      if(btn.classList.contains('selected')){
        btn.classList.remove('selected');
        responseDraft.frictions=responseDraft.frictions.filter(f=>f!==value);
      }else{
        if(responseDraft.frictions.length>=2){ showToast('Puedes elegir máximo 2 problemas.'); return; }
        btn.classList.add('selected'); responseDraft.frictions.push(value);
      }
    });

    function renderContextQuestion(){
      if(!responseDraft.stage){ responseDraft.stage='unknown'; }
      q('#stageBadge').textContent = stageLabels[responseDraft.stage];
      q('#contextQuestion').textContent = stageQuestions[responseDraft.stage];
    }
    function handleContextContinue(){
      const contextScore=scoreTo100(responseDraft.context || 3);
      if(contextScore>=75 && scoreTo100(responseDraft.global || 4)>=75){
        // salta fricción si experiencia positiva
        setStep(5);
      }else setStep(4);
    }

    function submitExperience(omit=false){
      if(!responseDraft.global) responseDraft.global=3;
      if(!responseDraft.stage) responseDraft.stage='unknown';
      if(!responseDraft.context) responseDraft.context=3;
      responseDraft.comment = omit ? '' : q('#patientComment').value.trim();
      const globalScore = scoreTo100(responseDraft.global);
      const contextScore = scoreTo100(responseDraft.context);
      const blendedScore = Math.round(globalScore*.45 + contextScore*.55);
      const classification = classifyScore(blendedScore);
      const severity = determineSeverity(blendedScore, responseDraft.frictions, responseDraft.comment);
      const item = {
        id: 'PX-' + Math.floor(2000 + Math.random()*7999),
        date: new Date().toLocaleString('es-PE',{hour:'2-digit',minute:'2-digit',day:'2-digit',month:'2-digit'}),
        stage: responseDraft.stage,
        stageLabel: stageLabels[responseDraft.stage],
        globalScore, contextScore, score: blendedScore,
        classification, severity,
        frictions:[...responseDraft.frictions], comment: responseDraft.comment,
        metric: metricMap[responseDraft.stage] || 'global'
      };
      state.responses.push(item); state.lastSubmitted=item;
      if(severity==='Alta' || classification==='negativo' || responseDraft.frictions.length){
        state.cases.push({ id:item.id, problem: deriveProblem(item), status:'Pendiente', priority: severity, item });
      }
      updateAll();
      const critical = severity==='Alta' || classification==='negativo';
      q('#finalIcon').style.background = critical ? 'var(--yellow-soft)' : 'var(--green-soft)';
      q('#finalIcon').style.color = critical ? 'var(--yellow)' : 'var(--green)';
      q('#finalIcon').textContent = critical ? '!' : '✓';
      q('#finalTitle').textContent = critical ? 'Gracias por contarnos.' : 'Gracias. Tu comentario ayuda a detectar mejoras concretas.';
      q('#finalText').textContent = critical ? 'Este comentario será priorizado para revisión por el equipo de calidad.' : 'La clínica podrá revisar esta información para mejorar la atención.';
      q('#caseCode').textContent = 'Respuesta registrada · Caso ' + item.id;
      setStep(6);
      showToast('Respuesta procesada: dashboard actualizado.');
    }

    function determineSeverity(score, frictions, comment){
      const criticalTerms = ['maltrato','no entendí','medicamento','receta','dolor','nadie','grave','reclamo','queja'];
      const sensitive = frictions.some(f=>['No entendí indicaciones','Trato poco amable','Problema de coordinación'].includes(f)) || criticalTerms.some(t=>comment.toLowerCase().includes(t));
      if(score<45 || sensitive) return 'Alta';
      if(score<70 || frictions.length>0) return 'Media';
      return 'Baja';
    }
    function deriveProblem(item){
      if(item.frictions.length) return item.frictions.join(', ');
      if(item.stage==='wait') return 'Tiempo de espera';
      if(item.stage==='communication') return 'Comprensión';
      if(item.stage==='clinical') return 'Trato recibido';
      return 'Experiencia negativa';
    }

    function avg(arr){ return arr.length ? Math.round(arr.reduce((a,b)=>a+b,0)/arr.length) : null; }
    function getMetrics(){
      const res=state.responses;
      const overall=avg(res.map(r=>r.score));
      const wait=avg(res.filter(r=>r.stage==='wait' || r.frictions.includes('Tiempo de espera')).map(r=>r.score));
      const treat=avg(res.filter(r=>r.stage==='clinical' || r.frictions.includes('Trato poco amable')).map(r=>r.score));
      const understand=avg(res.filter(r=>r.stage==='communication' || r.frictions.includes('No entendí indicaciones') || r.frictions.includes('Falta de información')).map(r=>r.score));
      const byStage={};
      Object.keys(stageLabels).filter(s=>s!=='unknown').forEach(s=>{
        const list=res.filter(r=>r.stage===s).map(r=>r.score);
        byStage[s]=avg(list);
      });
      return {overall,wait,treat,understand,byStage};
    }
    function setKpi(prefix, value){
      const val = value==null ? '—' : value;
      q('#'+prefix).textContent=val;
      const dot=q('#'+prefix+'Dot');
      dot.className='status-dot ' + (value==null?'warn':statusClass(value));
      const delta=q('#'+prefix+'Delta');
      if(delta){
        delta.className='kpi-delta ' + (value==null?'delta-warn': value>=75?'delta-good': value>=50?'delta-warn':'delta-bad');
        delta.textContent = value==null ? 'Sin datos suficientes' : statusLabel(value);
      }
    }
    function updateAll(){
      const m=getMetrics();
      setKpi('kpiGlobal',m.overall); setKpi('kpiWait',m.wait); setKpi('kpiTreat',m.treat); setKpi('kpiUnderstand',m.understand);
      updateStageBars(m.byStage); updateAlerts(); updateComments(); updateCases(); updateMirror();
      q('#lastUpdate').textContent = new Date().toLocaleTimeString('es-PE',{hour:'2-digit',minute:'2-digit'});
    }
    function updateStageBars(byStage){
      const wrap=q('#stageBars'); wrap.innerHTML='';
      Object.keys(stageLabels).filter(s=>s!=='unknown').forEach(s=>{
        const val = byStage[s]; const display = val==null ? 0 : val; const cls = val==null ? 'warn' : statusClass(val);
        const row=document.createElement('div'); row.className='stage-row';
        row.innerHTML = `<div class="stage-name">${stageLabels[s]}</div><div class="bar"><span class="${cls}" style="width:${val==null?8:val}%"></span></div><div class="score">${val==null?'—':val}</div>`;
        wrap.appendChild(row);
      });
    }
    function updateAlerts(){
      const wrap=q('#alertsList');
      const alerts=state.responses.filter(r=>r.severity==='Alta' || r.classification==='negativo' || r.frictions.length>0).slice().reverse();
      if(!alerts.length){ wrap.innerHTML='<div class="empty">Sin alertas. Registra una respuesta negativa o carga escenario demo.</div>'; return; }
      wrap.innerHTML=alerts.map(r=>{
        const cls = r.severity==='Alta' ? 'red':'yellow';
        const action = r.severity==='Alta' ? 'Activar service recovery' : 'Revisar proceso';
        return `<div class="alert ${cls}"><div class="alert-title">${deriveProblem(r)}</div><div class="meta"><span class="tag ${r.severity==='Alta'?'tag-red':'tag-yellow'}">${r.severity}</span><span class="tag tag-blue">${r.stageLabel}</span>${action} · Caso ${r.id}</div></div>`
      }).join('');
    }
    function updateComments(){
      const wrap=q('#commentsList');
      const comments=state.responses.filter(r=>r.comment).slice().reverse();
      if(!comments.length){ wrap.innerHTML='<div class="empty">Aún no hay comentarios registrados.</div>'; return; }
      wrap.innerHTML=comments.map(r=>`<div class="comment"><div><span class="tag tag-blue">${r.stageLabel}</span><span class="tag ${r.severity==='Alta'?'tag-red':r.severity==='Media'?'tag-yellow':'tag-green'}">${r.severity}</span></div><p style="margin:10px 0 8px;color:var(--text);font-weight:700">“${escapeHtml(r.comment)}”</p><div class="meta">${deriveProblem(r)} · ${r.date}</div></div>`).join('');
    }
    function updateCases(){
      const tbody=q('#casesTable');
      if(!state.cases.length){ tbody.innerHTML='<tr><td colspan="4" style="border-radius:14px;border:1px dashed var(--border);color:var(--muted)">Sin casos abiertos.</td></tr>'; return; }
      tbody.innerHTML=state.cases.slice().reverse().map(c=>`<tr><td><b>${c.id}</b><br><span class="meta">${c.item.stageLabel}</span></td><td>${escapeHtml(c.problem)}</td><td><span class="tag ${c.status==='Resuelto'?'tag-green':c.status==='En proceso'?'tag-blue':'tag-yellow'}">${c.status}</span></td><td><button class="mini-btn" onclick="openCase('${c.id}')">Ver caso</button></td></tr>`).join('');
    }
    function updateMirror(){
      const item=state.lastSubmitted;
      if(!item){ return; }
      q('#mirrorGlobal').textContent=item.score;
      q('#mirrorGlobalDot').className='status-dot '+statusClass(item.score);
      q('#mirrorGlobalLabel').className='kpi-delta '+(item.score>=75?'delta-good':item.score>=50?'delta-warn':'delta-bad');
      q('#mirrorGlobalLabel').textContent=statusLabel(item.score);
      q('#mirrorStage').textContent=item.stageLabel;
      q('#mirrorStageDot').className='status-dot '+statusClass(item.score);
      q('#mirrorStageLabel').className='kpi-delta '+(item.severity==='Alta'?'delta-bad':item.severity==='Media'?'delta-warn':'delta-good');
      q('#mirrorStageLabel').textContent='Severidad '+item.severity;
      const insight = buildInsight(item);
      q('#mirrorInsight').textContent=insight;
      q('#processingBox').textContent = JSON.stringify({
        respuesta:item.id, etapa:item.stageLabel, score:item.score, clasificacion:item.classification, severidad:item.severity,
        fricciones:item.frictions, kpi_afectado: kpiName(item.metric), accion_sugerida: suggestedAction(item)
      }, null, 2);
    }
    function buildInsight(item){
      if(item.stage==='wait' || item.frictions.includes('Tiempo de espera')) return 'Fricción detectada en tiempo de espera: revisar programación, comunicación de demoras y flujo de atención.';
      if(item.stage==='communication' || item.frictions.includes('No entendí indicaciones') || item.frictions.includes('Falta de información')) return 'Riesgo de baja comprensión: reforzar indicaciones y activar seguimiento si la severidad es alta.';
      if(item.stage==='clinical' || item.frictions.includes('Trato poco amable')) return 'Fricción en trato/escucha: revisar interacción del equipo y retroalimentar al servicio.';
      if(item.stage==='admin' || item.frictions.includes('Trámite confuso')) return 'Fricción administrativa: simplificar pasos y revisar claridad de orientación.';
      return item.classification==='positivo' ? 'Experiencia positiva registrada: útil para identificar buenas prácticas.' : 'Experiencia con oportunidad de mejora: revisar etapa y categoría asociada.';
    }
    function suggestedAction(item){
      if(item.severity==='Alta') return 'Activar service recovery y asignar responsable';
      if(item.frictions.length) return 'Generar acción de mejora por etapa';
      return 'Monitorear tendencia';
    }
    function kpiName(metric){ return ({global:'Experiencia global',wait:'Tiempo de espera percibido',treat:'Trato recibido',understand:'Comprensión del paciente'})[metric] || 'Experiencia global'; }
    function escapeHtml(s){ return s.replace(/[&<>'"]/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c])); }

    function openCase(id){
      currentCaseId=id;
      const c=state.cases.find(x=>x.id===id); if(!c) return;
      q('#modalTitle').textContent='Caso '+c.id+' · '+c.priority;
      q('#modalDesc').textContent=`${c.item.stageLabel} · ${c.problem}`;
      q('#modalPayload').textContent=JSON.stringify({comentario:c.item.comment||'(sin comentario)', score:c.item.score, estado:c.status, accion_sugerida:suggestedAction(c.item), responsable:'Equipo de calidad / jefe de servicio'}, null, 2);
      q('#caseModal').classList.add('show');
    }
    function closeModal(){ q('#caseModal').classList.remove('show'); currentCaseId=null; }
    function setCaseStatus(status){
      const c=state.cases.find(x=>x.id===currentCaseId); if(!c) return;
      c.status=status; updateCases(); showToast('Caso '+c.id+' actualizado: '+status); closeModal();
    }

    function resetPatientFlow(){
      responseDraft={global:null,stage:null,context:null,frictions:[],comment:''};
      qa('.option,.chip').forEach(b=>b.classList.remove('selected'));
      q('#patientComment').value=''; setStep(0);
    }
    q('#resetBtn').addEventListener('click',()=>{
      state={responses:[],cases:[],lastSubmitted:null}; resetPatientFlow(); updateAll();
      q('#mirrorGlobal').textContent='—'; q('#mirrorStage').textContent='—'; q('#mirrorGlobalLabel').textContent='Sin datos'; q('#mirrorStageLabel').textContent='Pendiente'; q('#mirrorInsight').textContent='Completa el flujo del paciente para generar un insight operativo.'; q('#processingBox').textContent='Esperando respuesta del paciente...';
      showToast('Prototipo reiniciado.');
    });
    function seedScenario(){
      const demo=[
        {stage:'wait',globalScore:40,contextScore:20,score:29,classification:'negativo',severity:'Alta',frictions:['Tiempo de espera','Falta de información'],comment:'Esperé demasiado y nadie me explicó por qué demoraba la consulta.',metric:'wait'},
        {stage:'clinical',globalScore:80,contextScore:100,score:91,classification:'positivo',severity:'Baja',frictions:[],comment:'La doctora me escuchó y explicó con paciencia.',metric:'treat'},
        {stage:'communication',globalScore:60,contextScore:20,score:38,classification:'negativo',severity:'Alta',frictions:['No entendí indicaciones'],comment:'Me dieron la receta pero no entendí cómo tomar mis medicamentos.',metric:'understand'},
        {stage:'admin',globalScore:60,contextScore:60,score:60,classification:'neutro',severity:'Media',frictions:['Trámite confuso'],comment:'El pago y el trámite fueron confusos.',metric:'global'}
      ].map((r,i)=>({id:'PX-'+(3000+i),date:new Date().toLocaleString('es-PE',{hour:'2-digit',minute:'2-digit',day:'2-digit',month:'2-digit'}),stageLabel:stageLabels[r.stage],...r}));
      state.responses.push(...demo); state.lastSubmitted=demo[demo.length-1];
      demo.filter(d=>d.severity!=='Baja').forEach(d=>state.cases.push({id:d.id,problem:deriveProblem(d),status:'Pendiente',priority:d.severity,item:d}));
      updateAll(); showToast('Escenario demo cargado.');
    }
    updateAll();
  </script>
